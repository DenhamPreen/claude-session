#!/usr/bin/env bash
# cproj-title — generate and cache an AI title for a Claude Code session.
# https://github.com/denhampreen/cproj
#
# Uses the local `claude` CLI (subscription auth) in headless, non-persistent
# mode — no API key required, no extra session files created.
#
# Usage:
#   cproj-title <transcript.jsonl>          # direct
#   cproj-title                             # reads Stop-hook JSON from stdin
#
# Env:
#   CPROJ_CLAUDE_BIN    override the `claude` binary (default: claude)
#   CPROJ_TITLE_MODEL   default: haiku
#   CPROJ_CACHE_DIR     default: ${XDG_CACHE_HOME:-~/.cache}/cproj
set -euo pipefail

# Recursion guard: if we ever invoke claude and its Stop hook calls us back,
# bail out immediately instead of generating a title-of-a-title.
[ "${CPROJ_TITLE_GEN:-0}" = "1" ] && exit 0

CLAUDE_BIN="${CPROJ_CLAUDE_BIN:-claude}"
MODEL="${CPROJ_TITLE_MODEL:-haiku}"
CACHE_DIR="${CPROJ_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/cproj}"
CACHE_FILE="$CACHE_DIR/titles.tsv"
TITLE_GEN_CWD="$CACHE_DIR/title-gen"
mkdir -p "$CACHE_DIR" "$TITLE_GEN_CWD"
: >> "$CACHE_FILE"

command -v jq >/dev/null || exit 0
command -v "$CLAUDE_BIN" >/dev/null || exit 0

if [ $# -ge 1 ]; then
  FILE="$1"
else
  [ -t 0 ] && { echo "cproj-title: need a file arg or JSON on stdin" >&2; exit 2; }
  payload=$(cat)
  FILE=$(printf '%s' "$payload" | jq -r '.transcript_path // empty')
fi

[ -n "${FILE:-}" ] && [ -f "$FILE" ] || exit 0

# Session metadata from the transcript.
read -r SID LAST_TS MSG_COUNT < <(jq -sr '
  [ .[] | select(.type=="user") | select(.isSidechain != true)
    | select(.message.content | type == "string")
    | select(.message.content | startswith("<") | not) ] as $u
  | if ($u|length)==0 then "\t\t0"
    else "\($u[0].sessionId)\t\($u[-1].timestamp)\t\($u|length)" end
' "$FILE")

[ -n "$SID" ] && [ "${MSG_COUNT:-0}" -gt 0 ] || exit 0

# Skip if we already generated a title from at least as many messages.
cached=$(awk -F'\t' -v s="$SID" '$1==s {n=$3} END{print n+0}' "$CACHE_FILE")
if [ "$cached" -ge "$MSG_COUNT" ]; then exit 0; fi

# First ~6 user messages, capped at 3000 chars — enough signal for a title.
SNIPPET=$(jq -sr '
  [ .[] | select(.type=="user") | select(.isSidechain != true)
    | select(.message.content | type == "string")
    | select(.message.content | startswith("<") | not)
    | .message.content ]
  | .[0:6] | join("\n---\n") | .[0:3000]
' "$FILE")

[ -n "$SNIPPET" ] || exit 0

PROMPT="Summarize this Claude Code session in a 4-7 word descriptive title.
Output only the title itself — no quotes, no trailing punctuation, no preamble.

--- session transcript ---
$SNIPPET"

# Run from an isolated cwd so we don't pick up any project's CLAUDE.md or
# settings. --no-session-persistence keeps this invocation out of
# ~/.claude/projects/. CPROJ_TITLE_GEN=1 short-circuits recursion.
title=$(
  cd "$TITLE_GEN_CWD"
  CPROJ_TITLE_GEN=1 "$CLAUDE_BIN" \
    -p --no-session-persistence --model "$MODEL" \
    --output-format text \
    "$PROMPT" 2>/dev/null
) || exit 0

title=$(printf '%s' "$title" \
  | tr '\n\t' '  ' \
  | sed -E 's/^[[:space:]"'"'"']+//; s/[[:space:]"'"'"'.]+$//' \
  | cut -c1-80)

[ -n "$title" ] || exit 0

printf '%s\t%s\t%s\t%s\n' "$SID" "$LAST_TS" "$MSG_COUNT" "$title" >> "$CACHE_FILE"
